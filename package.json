{
  "name": "hebrews-commentary",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PATH=./bin:$PATH NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next dev --webpack",
    "build": "PATH=./bin:$PATH NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next build --webpack",
    "start": "PATH=./bin:$PATH next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:theology": "node scripts/validate-theology.mjs",
    "validate:theology:draft": "node scripts/validate-theology.mjs --allow-pending-review",
    "audit:humanization": "node scripts/audit-humanization.mjs",
    "audit:copying": "node scripts/audit-copying.mjs",
    "audit:source-overlap": "node scripts/audit-private-overlap.mjs",
    "validate": "npm run validate:content && npm run audit:humanization && npm run validate:theology && npm run audit:copying && npm run audit:source-overlap",
    "reset:intake": "node generate-hebrews-intake.mjs",
    "import:kjv": "node import-hebrews-kjv.mjs",
    "import:commentary": "node import-hebrews-commentary.mjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-tabs": "latest",
    "@radix-ui/react-tooltip": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "framer-motion": "latest",
    "fuse.js": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "next-themes": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "^16.2.6",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.5.0",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest"
  }
}
